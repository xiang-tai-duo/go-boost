{
  "name": "electron-example",
  "version": "1.0.0",
  "description": "Simple Electron example",
  "author": "TRAE.AI",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.example.electron",
    "productName": "go-boost-electron",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "app.png"
    ],
    "win": {
      "icon": "app.png"
    }
  },
  "dependencies": {
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1"
  }
}
